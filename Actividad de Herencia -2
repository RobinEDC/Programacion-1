    }

    public class Lavadora : Electrodomestico
    {
        public Lavadora(string nombre, string marca) : base(nombre, marca)
        {
        }

        public override void Funcionar()
        {
            Console.WriteLine($"{Nombre} está lavando la ropa.");
        }
    }

    public class Microondas : Electrodomestico
    {
        public Microondas(string nombre, string marca) : base(nombre, marca)
        {
        }

        public override void Funcionar()
        {
            Console.WriteLine($"{Nombre} está calentando la comida.");
        }
    }

    public class CuentaBancaria
    {
        public string Titular { get; set; }
        public double Saldo { get; set; }

        public CuentaBancaria(string titular, double saldo)
        {
            Titular = titular;
            Saldo = saldo;
        }

        public virtual void MostrarCuenta()
        {
            Console.WriteLine($"Titular: {Titular}");
            Console.WriteLine($"Saldo: {Saldo:F2}");
        }
    }

    public class CuentaAhorro : CuentaBancaria
    {
        public double Interes { get; set; }

        public CuentaAhorro(string titular, double saldo, double interes) : base(titular, saldo)
        {
            Interes = interes;
        }

        public override void MostrarCuenta()
        {
            base.MostrarCuenta();
            Console.WriteLine($"Interés: {Interes}%");
        }
    }

    public class CuentaCorriente : CuentaBancaria
    {
        public double LimiteSobregiro { get; set; }

        public CuentaCorriente(string titular, double saldo, double limiteSobregiro) : base(titular, saldo)
        {
            LimiteSobregiro = limiteSobregiro;
        }

        public override void MostrarCuenta()
        {
            base.MostrarCuenta();
            Console.WriteLine($"Límite de sobregiro: {LimiteSobregiro:F2}");
        }
    }
