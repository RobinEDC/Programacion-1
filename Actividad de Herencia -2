            Console.WriteLine("\nPresiona una tecla para continuar al ejemplo 2...");
            Console.ReadKey();

            Console.Clear();
            Ejemplo2Vehiculos();

            Console.WriteLine("\nPresiona una tecla para continuar al ejemplo 3...");
            Console.ReadKey();

            Console.Clear();
            Ejemplo3Empleados();

            Console.WriteLine("\nPresiona una tecla para continuar al ejemplo 4...");
            Console.ReadKey();

            Console.Clear();
