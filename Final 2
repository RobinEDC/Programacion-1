        {
            Console.WriteLine("========================================");
            Console.WriteLine("     BIBLIOTECA DE VIDEOJUEGOS");
            Console.WriteLine("========================================");
            Console.WriteLine("1. Registrar videojuego físico");
            Console.WriteLine("2. Registrar videojuego digital");
            Console.WriteLine("3. Registrar usuario");
            Console.WriteLine("4. Mostrar todos los videojuegos");
            Console.WriteLine("5. Mostrar videojuegos disponibles");
            Console.WriteLine("6. Mostrar usuarios");
            Console.WriteLine("7. Prestar videojuego");
            Console.WriteLine("8. Devolver videojuego");
            Console.WriteLine("9. Mostrar préstamos");
            Console.WriteLine("10. Buscar videojuego por título");
            Console.WriteLine("11. Buscar videojuego por género");
            Console.WriteLine("0. Salir");
            Console.WriteLine("========================================");
        }

        /*
        ----------------------------------------
        FUNCIONES DE APOYO
        Sirven para leer datos de forma más segura
        ----------------------------------------
        */
        static int LeerEntero(string mensaje)
        {
            int valor;
            Console.Write(mensaje);

            while (!int.TryParse(Console.ReadLine(), out valor))
            {
                Console.Write("Entrada inválida. Intente de nuevo: ");
            }

            return valor;
        }

        static string LeerTexto(string mensaje)
        {
            string texto;
            Console.Write(mensaje);
            texto = Console.ReadLine();

            while (string.IsNullOrWhiteSpace(texto))
            {
                Console.Write("No puede dejar este campo vacío. Intente de nuevo: ");
                texto = Console.ReadLine();
            }

            return texto;
        }

        /*
        ----------------------------------------
        OPCIONES DEL MENÚ
        Cada función corresponde a una acción del sistema
        ----------------------------------------
        */
        static void RegistrarVideojuegoFisico(BibliotecaVideojuegos biblioteca)
        {
            string titulo = LeerTexto("Título: ");
            string genero = LeerTexto("Género: ");
            string plataforma = LeerTexto("Plataforma: ");
            int anio = LeerEntero("Año: ");
            string estadoDisco = LeerTexto("Estado del disco: ");

            biblioteca.RegistrarVideojuegoFisico(titulo, genero, plataforma, anio, estadoDisco);
            Console.WriteLine("Videojuego físico registrado correctamente.");
        }

        static void RegistrarVideojuegoDigital(BibliotecaVideojuegos biblioteca)
        {
            string titulo = LeerTexto("Título: ");
            string genero = LeerTexto("Género: ");
            string plataforma = LeerTexto("Plataforma: ");
            int anio = LeerEntero("Año: ");
            string tienda = LeerTexto("Tienda digital: ");

            biblioteca.RegistrarVideojuegoDigital(titulo, genero, plataforma, anio, tienda);
            Console.WriteLine("Videojuego digital registrado correctamente.");
        }

        static void RegistrarUsuario(BibliotecaVideojuegos biblioteca)
        {
            string nombre = LeerTexto("Nombre del usuario: ");
            string correo = LeerTexto("Correo: ");

            biblioteca.RegistrarUsuario(nombre, correo);
            Console.WriteLine("Usuario registrado correctamente.");
        }

        static void RealizarPrestamo(BibliotecaVideojuegos biblioteca)
        {
            int idUsuario = LeerEntero("ID del usuario: ");
            int idJuego = LeerEntero("ID del videojuego: ");

            bool resultado = biblioteca.PrestarVideojuego(idUsuario, idJuego);

            if (resultado)
            {
                Console.WriteLine("Préstamo realizado correctamente.");
            }
            else
            {
                Console.WriteLine("No se pudo realizar el préstamo. Verifique el ID o la disponibilidad del juego.");
            }
        }

        static void RealizarDevolucion(BibliotecaVideojuegos biblioteca)
        {
            int idJuego = LeerEntero("ID del videojuego a devolver: ");

            bool resultado = biblioteca.DevolverVideojuego(idJuego);

            if (resultado)
            {
                Console.WriteLine("Devolución realizada correctamente.");
            }
            else
            {
                Console.WriteLine("No se encontró un préstamo activo para ese videojuego.");
            }
        }

        static void BuscarPorTitulo(BibliotecaVideojuegos biblioteca)
        {
            string titulo = LeerTexto("Ingrese el título a buscar: ");
            biblioteca.BuscarVideojuegoPorTitulo(titulo);
        }

        static void BuscarPorGenero(BibliotecaVideojuegos biblioteca)
        {
            string genero = LeerTexto("Ingrese el género a buscar: ");
            biblioteca.BuscarVideojuegoPorGenero(genero);
        }
    }
}
