        }
    }

    /*
    ----------------------------------------
    CLASE PROGRAM
    Punto de entrada del sistema con menú interactivo
    ----------------------------------------
    */
    class Program
    {
        static void Main(string[] args)
        {
            BibliotecaVideojuegos biblioteca = new BibliotecaVideojuegos();
            biblioteca.CargarDatosIniciales();

            int opcion;

            do
            {
                MostrarMenu();
                opcion = LeerEntero("Seleccione una opción: ");

                Console.WriteLine();

                switch (opcion)
                {
                    case 1:
                        RegistrarVideojuegoFisico(biblioteca);
                        break;

                    case 2:
                        RegistrarVideojuegoDigital(biblioteca);
                        break;

                    case 3:
                        RegistrarUsuario(biblioteca);
                        break;

                    case 4:
                        biblioteca.MostrarVideojuegos();
                        break;

                    case 5:
                        biblioteca.MostrarVideojuegosDisponibles();
                        break;

                    case 6:
                        biblioteca.MostrarUsuarios();
                        break;

                    case 7:
                        RealizarPrestamo(biblioteca);
                        break;

                    case 8:
                        RealizarDevolucion(biblioteca);
                        break;

                    case 9:
                        biblioteca.MostrarPrestamos();
                        break;

                    case 10:
                        BuscarPorTitulo(biblioteca);
                        break;

                    case 11:
                        BuscarPorGenero(biblioteca);
                        break;

                    case 0:
                        Console.WriteLine("Saliendo del sistema...");
                        break;

                    default:
                        Console.WriteLine("Opción no válida.");
                        break;
                }

                Console.WriteLine();
            }
            while (opcion != 0);
        }

        /*
        ----------------------------------------
        MENÚ PRINCIPAL
        Muestra todas las opciones del programa
        ----------------------------------------
        */
